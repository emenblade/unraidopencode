# Copy this file to .env and fill in values before running docker compose.

# Required. Protects the opencode web UI with HTTP Basic Auth.
# Generate one with: openssl rand -base64 24
OPENCODE_SERVER_PASSWORD=changeme-generate-a-long-random-value

# Optional. Basic auth username (default: opencode).
# OPENCODE_SERVER_USERNAME=opencode

# Port exposed on the host. The container always listens on 4096 internally.
OPENCODE_PORT=4096

# Address to bind on the host. 0.0.0.0 (default) makes it reachable from
# other devices on your LAN / over WireGuard. Use 127.0.0.1 instead if you
# only ever want to reach it from the Unraid box itself (e.g. via SSH tunnel).
BIND_ADDRESS=0.0.0.0

TZ=UTC

# Where opencode's config/credentials/session history live. On Unraid, point
# this at your appdata share so it's covered by the CA Backup/Restore plugin:
#   APPDATA_PATH=/mnt/user/appdata/opencode-mobile
APPDATA_PATH=./appdata

# Where the code you want opencode to work on lives. On Unraid, point this
# at whatever share holds your projects, e.g.:
#   WORKSPACE_PATH=/mnt/user/projects
WORKSPACE_PATH=./workspace

# Optional. GitHub Personal Access Token (classic, repo scope) for git push/pull
# from inside the container. If set, the entrypoint configures git credentials.
# GITHUB_TOKEN=ghp_xxx
