# Copy this file to .env and fill in values before running docker compose.

# Required. Protects the opencode web UI with HTTP Basic Auth.
# Generate one with: openssl rand -base64 24
OPENCODE_SERVER_PASSWORD=changeme-generate-a-long-random-value

# Optional. Basic auth username (default: opencode).
# OPENCODE_SERVER_USERNAME=opencode

# Port exposed on the host. The container always listens on 4096 internally.
OPENCODE_PORT=4096

# Address to bind on the host:
#   127.0.0.1 (default) - only reachable from this machine (e.g. via SSH tunnel)
#   0.0.0.0             - reachable from other devices on your LAN
BIND_ADDRESS=127.0.0.1

TZ=UTC

# --- Only needed with docker-compose.tailscale.yml ---
# Auth key from https://login.tailscale.com/admin/settings/keys
# (an ephemeral, reusable key is convenient for a container)
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# --- Only needed with docker-compose.public.yml ---
# DOMAIN=opencode.example.com
